# ---- Data (do not commit raw/large data) ----
data/raw/*
data/interim/*
data/processed/*
!data/**/.gitkeep

# ---- Models & artifacts ----
models/*
!models/.gitkeep
mlruns/
mlartifacts/
*.pkl
*.joblib
*.onnx

# ---- Secrets & config ----
.env
*.key
*-key.json
gcp-credentials*.json

# ---- Python ----
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/
.ipynb_checkpoints/

# ---- Virtual environments ----
.venv/
venv/
env/
.conda/

# ---- Reports (keep figures folder, ignore heavy exports) ----
reports/figures/*
!reports/figures/.gitkeep

# ---- Tooling ----
.pytest_cache/
.ruff_cache/
.mypy_cache/
.coverage
htmlcov/

# ---- OS / IDE ----
.DS_Store
Thumbs.db
.vscode/
.idea/
