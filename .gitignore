# ---- Data ----
# The raw CSV IS committed: 1.7MB synthetic Kaggle data -> repo is fully
# reproducible and CI/Docker builds are self-contained. Derived data is not.
data/interim/*
data/processed/*
!data/**/.gitkeep
# Committed so Streamlit Cloud can serve the dashboard without retraining:
!data/processed/churn_features.parquet

# ---- Models & artifacts ----
models/*
!models/.gitkeep
# Committed for Streamlit Cloud deployment (0.9MB, deterministic seed 42):
!models/churn_model.joblib
!models/model_meta.json
mlruns/
mlartifacts/
mlflow.db
*.pkl
*.joblib
*.onnx
# negation must follow the *.joblib pattern above
!models/churn_model.joblib

# ---- Secrets & config ----
.env
*.key
*-key.json
gcp-credentials*.json

# ---- Python ----
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/
.ipynb_checkpoints/

# ---- Virtual environments ----
.venv/
venv/
env/
.conda/

# ---- Reports: figures are committed (portfolio assets); generated HTML is not ----
reports/drift_report.html

# ---- Tooling ----
.pytest_cache/
.ruff_cache/
.mypy_cache/
.coverage
htmlcov/

# ---- OS / IDE ----
.DS_Store
Thumbs.db
.vscode/
.idea/
